DATABASE_URL=sqlite:///./vera.db
# For PostgreSQL (Docker / production):
# DATABASE_URL=postgresql+psycopg2://vera:vera@localhost:5432/vera

SECRET_KEY=change-this-to-a-long-random-secret-key
ACCESS_TOKEN_EXPIRE_MINUTES=1440
CORS_ORIGINS=http://localhost:3000

# Optional email channel (leave blank to keep in-app only)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=vera@localhost

# Optional SMS channel (demo/stub provider)
SMS_ENABLED=false
SMS_PROVIDER_URL=
SMS_API_KEY=
